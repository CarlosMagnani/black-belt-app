+              ref={confirmRef}
+              className="min-h-[50px] w-full bg-transparent text-red uppercase font-display text-[15px] tracking-[0.01em] px-4 transition disabled:opacity-40"
+              onClick={onConfirm}
+              disabled={isLoading}
+              type="button"
+            >
+              {isLoading ? 'PROCESSANDO...' : confirmLabel}
+            </button>
+          )}
+        </div>
+      </Card>
+    </div>
+  )
